# https://goframe.org/docs/web/server-config-file-template
server:
  address:     ":10027"
  openapiPath: "/api.json"
  swaggerPath: "/swagger"

# https://goframe.org/docs/core/glog-config
logger:
  level : "all"
  stdout: true

# https://goframe.org/docs/core/gdb-config-file
# member 业务表使用 funddisk 库
database:
  default:
    link: "mysql:sql_funddisk_easytestdev_online:daa5129899a218@tcp(127.0.0.1:3306)/sql_funddisk_easytestdev_online"
    debug: true
    charset: "utf8mb4"

# https://goframe.org/docs/components/os-gredis-config
redis:
  default:
    address: "127.0.0.1:6379"
    pass: "123456"
    db: 0

# JWT 配置
# - secret 是后台 token 密钥（system/upload 同源），≥32 字符
# - memberSecret 是 C 端会员 token 密钥，必须与后台分离避免互通
jwt:
  secret: "change_me_at_least_32_chars_long_secret_xxxxxx"
  memberSecret: "change_me_member_secret_at_least_32_chars_long_xxxx"
  expire: 24

# 应用间票据互通配置
sso:
  appId: "gbaseadmin-admin"
  sharedKey: "change_me_shared_sso_key"
  ticketExpireSeconds: 60

# 短信验证码（C 端注册 / 找回密码 / 修改手机号）
# - 默认走 mock 通道，固定验证码 123456，仅供本地联调；生产必须改成 aliyun
# - codeExpireSeconds 验证码有效期；limitSeconds 同手机号同场景重发间隔；verifyMaxAttempts 校验最大错误次数
sms:
  provider: "mock"
  codeExpireSeconds: 300
  limitSeconds: 60
  verifyMaxAttempts: 5
  providers:
    mock:
      kind: "mock"
      fixedCode: "123456"
    aliyun:
      kind: "aliyun"
      region: "cn-hangzhou"
      accessKeyId: ""
      accessKeySecret: ""
      signName: ""
      templateCode: ""

# 会员业务配置
# - h5BaseURL 用于生成邀请链接 / 二维码内容（H5 SPA 部署后可改）
# - inviteCodeLength 邀请码长度（8 位 base32 已够大）
# - registerRequireInviteCode 注册是否必须填邀请码（true 表示找不到上级则拒绝注册）
member:
  h5BaseURL: "https://funddisk.easytestdev.online/h5"
  inviteCodeLength: 8
  registerRequireInviteCode: true
  # 合同 HTML/PDF 落盘路径（异步生成，可被 download 接口流式回吐）
  contractStorageDir: "./runtime/contracts"
  # Chromium 二进制路径（用于服务端渲染合同 PDF）。留空则按 PATH 探测：
  #   ungoogled-chromium / chromium / chromium-browser / google-chrome / google-chrome-stable
  contractChromiumPath: ""
