
package tag

import (
	"context"
	"encoding/csv"
	"io"
	"fmt"

	"github.com/gogf/gf/v2/database/gdb"
	"github.com/gogf/gf/v2/errors/gerror"
	"github.com/gogf/gf/v2/frame/g"
	"github.com/gogf/gf/v2/net/ghttp"

	"gbaseadmin/app/demo/internal/dao"
	"gbaseadmin/app/demo/internal/middleware"
	"gbaseadmin/app/demo/internal/model"
	"gbaseadmin/app/demo/internal/model/do"
	"gbaseadmin/app/demo/internal/service"
	"gbaseadmin/utility/snowflake"
)

func init() {
	service.RegisterTag(New())
}

func New() *sTag {
	return &sTag{}
}

type sTag struct{}

func normalizeTagIDs(ids []snowflake.JsonInt64) []snowflake.JsonInt64 {
	if len(ids) == 0 {
		return nil
	}
	seen := make(map[int64]struct{}, len(ids))
	normalized := make([]snowflake.JsonInt64, 0, len(ids))
	for _, id := range ids {
		value := int64(id)
		if value <= 0 {
			continue
		}
		if _, ok := seen[value]; ok {
			continue
		}
		seen[value] = struct{}{}
		normalized = append(normalized, id)
		if len(normalized) >= 500 {
			break
		}
	}
	if len(normalized) == 0 {
		return nil
	}
	return normalized
}

// Create 创建标签
func (s *sTag) Create(ctx context.Context, in *model.TagCreateInput) error {
	id := snowflake.Generate()
	middleware.ApplyTenantScopeToWrite(ctx, &in.TenantID, &in.MerchantID)
	if err := middleware.EnsureTenantMerchantAccessible(ctx, in.TenantID, in.MerchantID); err != nil {
		return err
	}
	_, err := dao.DemoTag.Ctx(ctx).Data(do.DemoTag{
		Id:        id,
		Name: in.Name,
		Color: in.Color,
		Sort: in.Sort,
		Status: in.Status,
		TenantId: in.TenantID,
		MerchantId: in.MerchantID,
		CreatedBy: middleware.GetUserID(ctx),
		DeptId: middleware.GetDeptID(ctx),
	}).Insert()
	return err
}

// Update 更新标签
func (s *sTag) Update(ctx context.Context, in *model.TagUpdateInput) error {
	middleware.ApplyTenantScopeToWrite(ctx, &in.TenantID, &in.MerchantID)
	if err := middleware.EnsureTenantMerchantAccessible(ctx, in.TenantID, in.MerchantID); err != nil {
		return err
	}
	if err := middleware.EnsureTenantScopedRowAccessible(ctx, dao.DemoTag.Ctx(ctx), in.ID, dao.DemoTag.Columns().Id, dao.DemoTag.Columns().TenantId, dao.DemoTag.Columns().MerchantId, "标签"); err != nil {
		return err
	}
	if err := middleware.EnsureDataScopedRowAccessible(ctx, dao.DemoTag.Ctx(ctx), in.ID, dao.DemoTag.Columns().Id, dao.DemoTag.Columns().CreatedBy, dao.DemoTag.Columns().DeptId); err != nil {
		return err
	}
	data := do.DemoTag{
		Name: in.Name,
		Color: in.Color,
		Sort: in.Sort,
		Status: in.Status,
		TenantId: in.TenantID,
		MerchantId: in.MerchantID,
	}
	_, err := dao.DemoTag.Ctx(ctx).Where(dao.DemoTag.Columns().Id, in.ID).Where(dao.DemoTag.Columns().DeletedAt, nil).Data(data).Update()
	return err
}

// Delete 软删除标签
func (s *sTag) Delete(ctx context.Context, id snowflake.JsonInt64) error {
	if err := middleware.EnsureTenantScopedRowAccessible(ctx, dao.DemoTag.Ctx(ctx), id, dao.DemoTag.Columns().Id, dao.DemoTag.Columns().TenantId, dao.DemoTag.Columns().MerchantId, "标签"); err != nil {
		return err
	}
	if err := middleware.EnsureDataScopedRowAccessible(ctx, dao.DemoTag.Ctx(ctx), id, dao.DemoTag.Columns().Id, dao.DemoTag.Columns().CreatedBy, dao.DemoTag.Columns().DeptId); err != nil {
		return err
	}
	_, err := dao.DemoTag.Ctx(ctx).Where(dao.DemoTag.Columns().Id, id).Delete()
	return err
}

// BatchDelete 批量软删除标签
func (s *sTag) BatchDelete(ctx context.Context, ids []snowflake.JsonInt64) error {
	normalizedIDs := normalizeTagIDs(ids)
	if len(normalizedIDs) == 0 {
		return nil
	}
	if err := middleware.EnsureTenantScopedRowsAccessible(ctx, dao.DemoTag.Ctx(ctx), normalizedIDs, dao.DemoTag.Columns().Id, dao.DemoTag.Columns().TenantId, dao.DemoTag.Columns().MerchantId, "标签"); err != nil {
		return err
	}
	if err := middleware.EnsureDataScopedRowsAccessible(ctx, dao.DemoTag.Ctx(ctx), normalizedIDs, dao.DemoTag.Columns().Id, dao.DemoTag.Columns().CreatedBy, dao.DemoTag.Columns().DeptId); err != nil {
		return err
	}
	_, err := dao.DemoTag.Ctx(ctx).WhereIn(dao.DemoTag.Columns().Id, normalizedIDs).Delete()
	return err
}

// Detail 获取标签详情
func (s *sTag) Detail(ctx context.Context, id snowflake.JsonInt64) (out *model.TagDetailOutput, err error) {
	if err = middleware.EnsureTenantScopedRowAccessible(ctx, dao.DemoTag.Ctx(ctx), id, dao.DemoTag.Columns().Id, dao.DemoTag.Columns().TenantId, dao.DemoTag.Columns().MerchantId, "标签"); err != nil {
		return nil, err
	}
	if err = middleware.EnsureDataScopedRowAccessible(ctx, dao.DemoTag.Ctx(ctx), id, dao.DemoTag.Columns().Id, dao.DemoTag.Columns().CreatedBy, dao.DemoTag.Columns().DeptId); err != nil {
		return nil, err
	}
	out = &model.TagDetailOutput{}
	err = dao.DemoTag.Ctx(ctx).Where(dao.DemoTag.Columns().Id, id).Where(dao.DemoTag.Columns().DeletedAt, nil).Scan(out)
	if err != nil {
		return nil, err
	}
	if out == nil || out.ID == 0 {
		return nil, gerror.New("标签不存在或已删除")
	}
	// 查询租户关联显示
	if out.TenantID != 0 {
		refQuery := g.DB().Ctx(ctx).Model("system_tenant").Where("id", out.TenantID)
		val, err := refQuery.Value("name")
		if err == nil {
			out.TenantName = val.String()
		}
	}
	// 查询商户关联显示
	if out.MerchantID != 0 {
		refQuery := g.DB().Ctx(ctx).Model("system_merchant").Where("id", out.MerchantID)
		val, err := refQuery.Value("name")
		if err == nil {
			out.MerchantName = val.String()
		}
	}
	return
}

// applyListFilter 应用列表通用过滤条件
func (s *sTag) applyListFilter(ctx context.Context, in *model.TagListInput) *gdb.Model {
	m := dao.DemoTag.Ctx(ctx).Where(dao.DemoTag.Columns().DeletedAt, nil)
	m = middleware.ApplyTenantScopeToModel(ctx, m, dao.DemoTag.Columns().TenantId, dao.DemoTag.Columns().MerchantId)
	if in.Name != "" {
		m = m.WhereLike(dao.DemoTag.Columns().Name, "%"+in.Name+"%")
	}
	if in.TenantID != nil {
		m = m.Where(dao.DemoTag.Columns().TenantId, *in.TenantID)
	}
	if in.MerchantID != nil {
		m = m.Where(dao.DemoTag.Columns().MerchantId, *in.MerchantID)
	}
	if in.Status != nil {
		m = m.Where(dao.DemoTag.Columns().Status, *in.Status)
	}
	if in.StartTime != "" {
		m = m.WhereGTE(dao.DemoTag.Columns().CreatedAt, in.StartTime)
	}
	if in.EndTime != "" {
		m = m.WhereLTE(dao.DemoTag.Columns().CreatedAt, in.EndTime)
	}
	// 数据权限过滤
	m = middleware.ApplyDataScope(ctx, m, dao.DemoTag.Columns().CreatedBy, dao.DemoTag.Columns().DeptId)
	return m
}

// fillRefFields 批量填充关联显示字段（避免 N+1 查询）
func (s *sTag) fillRefFields(ctx context.Context, list []*model.TagListOutput) {
	{
		idSet := make(map[int64]struct{})
		for _, item := range list {
			if item.TenantID != 0 {
				idSet[int64(item.TenantID)] = struct{}{}
			}
		}
		if len(idSet) > 0 {
			ids := make([]int64, 0, len(idSet))
			for id := range idSet {
				ids = append(ids, id)
			}
			refQuery := g.DB().Ctx(ctx).Model("system_tenant").
				Fields("id", "name")
			rows, err := refQuery.WhereIn("id", ids).All()
			if err == nil {
				refMap := make(map[int64]string, len(rows))
				for _, row := range rows {
					refMap[row["id"].Int64()] = row["name"].String()
				}
				for _, item := range list {
					if val, ok := refMap[int64(item.TenantID)]; ok {
						item.TenantName = val
					}
				}
			}
		}
	}
	{
		idSet := make(map[int64]struct{})
		for _, item := range list {
			if item.MerchantID != 0 {
				idSet[int64(item.MerchantID)] = struct{}{}
			}
		}
		if len(idSet) > 0 {
			ids := make([]int64, 0, len(idSet))
			for id := range idSet {
				ids = append(ids, id)
			}
			refQuery := g.DB().Ctx(ctx).Model("system_merchant").
				Fields("id", "name")
			rows, err := refQuery.WhereIn("id", ids).All()
			if err == nil {
				refMap := make(map[int64]string, len(rows))
				for _, row := range rows {
					refMap[row["id"].Int64()] = row["name"].String()
				}
				for _, item := range list {
					if val, ok := refMap[int64(item.MerchantID)]; ok {
						item.MerchantName = val
					}
				}
			}
		}
	}
}

// List 获取标签列表
func (s *sTag) List(ctx context.Context, in *model.TagListInput) (list []*model.TagListOutput, total int, err error) {
	if in == nil {
		in = &model.TagListInput{}
	}
	// PageSize 上限保护
	if in.PageSize <= 0 {
		in.PageSize = 10
	} else if in.PageSize > 500 {
		in.PageSize = 500
	}
	if in.PageNum <= 0 {
		in.PageNum = 1
	}
	m := s.applyListFilter(ctx, in)
	total, err = m.Count()
	if err != nil {
		return
	}
	// 动态排序（白名单校验防止 SQL 注入）
	m = s.applyListOrder(m, in.OrderBy, in.OrderDir)
	err = m.Page(in.PageNum, in.PageSize).Scan(&list)
	if err != nil {
		return
	}
	s.fillRefFields(ctx, list)
	return
}

// isAllowedOrderField 校验排序字段是否在允许列表中
func (s *sTag) isAllowedOrderField(field string) bool {
	allowed := map[string]bool{
		dao.DemoTag.Columns().Id:        true,
		dao.DemoTag.Columns().CreatedAt: true,
		dao.DemoTag.Columns().Sort:      true,
		dao.DemoTag.Columns().Status:    true,
		dao.DemoTag.Columns().Name: true,
	}
	return allowed[field]
}

func (s *sTag) applyListOrder(m *gdb.Model, orderBy, orderDir string) *gdb.Model {
	if orderBy != "" && s.isAllowedOrderField(orderBy) {
		if orderDir == "desc" {
			return m.OrderDesc(orderBy)
		}
		return m.OrderAsc(orderBy)
	}
	return m.OrderAsc(dao.DemoTag.Columns().Sort).OrderDesc(dao.DemoTag.Columns().Id)
}

// Export 导出标签（不分页）
func (s *sTag) Export(ctx context.Context, in *model.TagListInput) (list []*model.TagListOutput, err error) {
	if in == nil {
		in = &model.TagListInput{}
	}
	m := s.applyListFilter(ctx, in)
	err = s.applyListOrder(m, in.OrderBy, in.OrderDir).Limit(10000).Scan(&list)
	if err != nil {
		return
	}
	s.fillRefFields(ctx, list)
	return
}

// BatchUpdate 批量编辑标签
func (s *sTag) BatchUpdate(ctx context.Context, in *model.TagBatchUpdateInput) error {
	data := do.DemoTag{}
	hasChange := false
	if in.Status != nil {
		data.Status = *in.Status
		hasChange = true
	}
	if !hasChange {
		return nil
	}
	normalizedIDs := normalizeTagIDs(in.IDs)
	if len(normalizedIDs) == 0 {
		return nil
	}
	if err := middleware.EnsureTenantScopedRowsAccessible(ctx, dao.DemoTag.Ctx(ctx), normalizedIDs, dao.DemoTag.Columns().Id, dao.DemoTag.Columns().TenantId, dao.DemoTag.Columns().MerchantId, "标签"); err != nil {
		return err
	}
	if err := middleware.EnsureDataScopedRowsAccessible(ctx, dao.DemoTag.Ctx(ctx), normalizedIDs, dao.DemoTag.Columns().Id, dao.DemoTag.Columns().CreatedBy, dao.DemoTag.Columns().DeptId); err != nil {
		return err
	}
	_, err := dao.DemoTag.Ctx(ctx).WhereIn(dao.DemoTag.Columns().Id, normalizedIDs).Data(data).Update()
	return err
}

// Import 导入标签
func (s *sTag) Import(ctx context.Context, file *ghttp.UploadFile) (success int, fail int, err error) {
	const maxImportFileSize = 10 << 20 // 10MB
	const maxImportRows = 5000
	if file.Size > maxImportFileSize {
		return 0, 0, fmt.Errorf("文件大小超过限制（最大10MB）")
	}
	f, err := file.Open()
	if err != nil {
		return 0, 0, err
	}
	defer f.Close()

	reader := csv.NewReader(f)
	// 跳过表头
	if _, err = reader.Read(); err != nil {
		return 0, 0, fmt.Errorf("读取CSV表头失败: %w", err)
	}

	rowCount := 0
	for {
		record, readErr := reader.Read()
		if readErr != nil {
			if readErr == io.EOF {
				break
			}
			return success, fail, fmt.Errorf("读取CSV数据失败: %w", readErr)
		}
		if len(record) == 0 {
			continue
		}
		rowCount++
		if rowCount > maxImportRows {
			break
		}
		// 逐行插入
		id := snowflake.Generate()
		data := do.DemoTag{
			Id: id,
			CreatedBy: middleware.GetUserID(ctx),
			DeptId: middleware.GetDeptID(ctx),
		}
		idx := 0
		if idx < len(record) {
			data.Name = record[idx]
		}
		idx++
		if idx < len(record) {
			data.Color = record[idx]
		}
		idx++
		if idx < len(record) {
			data.Sort = record[idx]
		}
		idx++
		if idx < len(record) {
			data.Status = record[idx]
		}
		idx++
		tenantID := snowflake.JsonInt64(0)
		merchantID := snowflake.JsonInt64(0)
		middleware.ApplyTenantScopeToWrite(ctx, &tenantID, &merchantID)
		if err := middleware.EnsureTenantMerchantAccessible(ctx, tenantID, merchantID); err != nil {
			fail++
			continue
		}
		data.TenantId = tenantID
		data.MerchantId = merchantID
		if _, insertErr := dao.DemoTag.Ctx(ctx).Data(data).Insert(); insertErr != nil {
			fail++
		} else {
			success++
		}
	}
	return
}

