package v1

import (
	"github.com/gogf/gf/v2/frame/g"
	"github.com/gogf/gf/v2/os/gtime"

	"gbaseadmin/app/demo/internal/model"
	"gbaseadmin/utility/snowflake"
)

// 确保 gtime 被引用
var _ = gtime.New

// Tag API

// TagCreateReq 创建标签请求
type TagCreateReq struct {
	g.Meta `path:"/tag/create" method:"post" tags:"标签" summary:"创建标签"`
	Name string `json:"name" v:"required|max-length:50" dc:"Name"`
	Color string `json:"color"  dc:"Color"`
	Sort int `json:"sort"  dc:"Sort"`
	Status int `json:"status"  dc:"Status"`
	TenantID snowflake.JsonInt64 `json:"tenantID"  dc:"租户"`
	MerchantID snowflake.JsonInt64 `json:"merchantID"  dc:"商户"`
}

// TagCreateRes 创建标签响应
type TagCreateRes struct {
	g.Meta `mime:"application/json"`
}

// TagUpdateReq 更新标签请求
type TagUpdateReq struct {
	g.Meta `path:"/tag/update" method:"put" tags:"标签" summary:"更新标签"`
	ID     snowflake.JsonInt64 `json:"id" v:"required#ID不能为空" dc:"标签ID"`
	Name string `json:"name" v:"max-length:50" dc:"Name"`
	Color string `json:"color"  dc:"Color"`
	Sort int `json:"sort"  dc:"Sort"`
	Status int `json:"status"  dc:"Status"`
	TenantID snowflake.JsonInt64 `json:"tenantID"  dc:"租户"`
	MerchantID snowflake.JsonInt64 `json:"merchantID"  dc:"商户"`
}

// TagUpdateRes 更新标签响应
type TagUpdateRes struct {
	g.Meta `mime:"application/json"`
}

// TagDeleteReq 删除标签请求
type TagDeleteReq struct {
	g.Meta `path:"/tag/delete" method:"delete" tags:"标签" summary:"删除标签"`
	ID     snowflake.JsonInt64 `json:"id" v:"required#ID不能为空" dc:"标签ID"`
}

// TagDeleteRes 删除标签响应
type TagDeleteRes struct {
	g.Meta `mime:"application/json"`
}

// TagBatchDeleteReq 批量删除标签请求
type TagBatchDeleteReq struct {
	g.Meta `path:"/tag/batch-delete" method:"delete" tags:"标签" summary:"批量删除标签"`
	IDs    []snowflake.JsonInt64 `json:"ids" v:"required#ID列表不能为空" dc:"标签ID列表"`
}

// TagBatchDeleteRes 批量删除标签响应
type TagBatchDeleteRes struct {
	g.Meta `mime:"application/json"`
}

// TagBatchUpdateReq 批量编辑标签请求
type TagBatchUpdateReq struct {
	g.Meta `path:"/tag/batch-update" method:"put" tags:"标签" summary:"批量编辑标签"`
	IDs    []snowflake.JsonInt64 `json:"ids" v:"required#ID列表不能为空" dc:"标签ID列表"`
	Status *int `json:"status" dc:"Status"`
}

// TagBatchUpdateRes 批量编辑标签响应
type TagBatchUpdateRes struct {
	g.Meta `mime:"application/json"`
}

// TagDetailReq 获取标签详情请求
type TagDetailReq struct {
	g.Meta `path:"/tag/detail" method:"get" tags:"标签" summary:"获取标签详情"`
	ID     snowflake.JsonInt64 `json:"id" v:"required#ID不能为空" dc:"标签ID"`
}

// TagDetailRes 获取标签详情响应
type TagDetailRes struct {
	g.Meta `mime:"application/json"`
	*model.TagDetailOutput
}

// TagListReq 获取标签列表请求
type TagListReq struct {
	g.Meta    `path:"/tag/list" method:"get" tags:"标签" summary:"获取标签列表"`
	PageNum   int    `json:"pageNum" d:"1" v:"min:1" dc:"页码"`
	PageSize  int    `json:"pageSize" d:"10" v:"between:1,500" dc:"每页数量"`
	OrderBy   string `json:"orderBy" dc:"排序字段"`
	OrderDir  string `json:"orderDir" d:"desc" v:"in:asc,desc" dc:"排序方向:asc/desc"`
	StartTime string `json:"startTime" dc:"开始时间"`
	EndTime   string `json:"endTime" dc:"结束时间"`
	Name string `json:"name" dc:"Name"`
	TenantID *snowflake.JsonInt64 `json:"tenantID" dc:"租户"`
	MerchantID *snowflake.JsonInt64 `json:"merchantID" dc:"商户"`
	Status *int `json:"status" dc:"Status"`
}

// TagListRes 获取标签列表响应
type TagListRes struct {
	g.Meta `mime:"application/json"`
	List   []*model.TagListOutput `json:"list" dc:"列表数据"`
	Total  int                               `json:"total" dc:"总数"`
}
// TagExportReq 导出标签请求
type TagExportReq struct {
	g.Meta    `path:"/tag/export" method:"get" tags:"标签" summary:"导出标签"`
	OrderBy   string `json:"orderBy" dc:"排序字段"`
	OrderDir  string `json:"orderDir" d:"desc" dc:"排序方向:asc/desc"`
	StartTime string `json:"startTime" dc:"开始时间"`
	EndTime   string `json:"endTime" dc:"结束时间"`
	Name string `json:"name" dc:"Name"`
	TenantID *snowflake.JsonInt64 `json:"tenantID" dc:"租户"`
	MerchantID *snowflake.JsonInt64 `json:"merchantID" dc:"商户"`
	Status *int `json:"status" dc:"Status"`
}

// TagExportRes 导出标签响应
type TagExportRes struct {
	g.Meta `mime:"text/csv"`
}

// TagImportReq 导入标签请求
type TagImportReq struct {
	g.Meta `path:"/tag/import" method:"post" mime:"multipart/form-data" tags:"标签" summary:"导入标签"`
}

// TagImportRes 导入标签响应
type TagImportRes struct {
	g.Meta  `mime:"application/json"`
	Success int `json:"success" dc:"成功条数"`
	Fail    int `json:"fail" dc:"失败条数"`
}

// TagImportTemplateReq 下载标签导入模板
type TagImportTemplateReq struct {
	g.Meta `path:"/tag/import-template" method:"get" tags:"标签" summary:"下载标签导入模板"`
}

// TagImportTemplateRes 下载标签导入模板响应
type TagImportTemplateRes struct {
	g.Meta `mime:"text/csv"`
}

