/** 文章类型定义 */

/** 文章项 */
export interface ArticleItem {
  id: string;
  categoryId: string;
  categoryName?: string;
  userId: string;
  usersUsername?: string;
  title: string;
  orderNo: string;
  cover?: string;
  attachmentFile?: string;
  bodyContent?: string;
  extraJSON?: string;
  linkURL?: string;
  status?: number;
  type?: number;
  isTop?: number;
  price?: number;
  sort?: number;
  icon?: string;
  email?: string;
  phone?: string;
  remark?: string;
  level?: string;
  extraField?: string;
  publishAt?: string;
  expireAt?: string;
  tenantID?: string;
  tenantName?: string;
  merchantID?: string;
  merchantName?: string;
  createdAt?: string;
  updatedAt?: string;
}

/** 文章列表查询参数 */
export interface ArticleListParams {
  pageNum: number;
  pageSize: number;
  orderBy?: string;
  orderDir?: string;
  startTime?: string;
  endTime?: string;
  keyword?: string;
  orderNo?: string;
  title?: string;
  email?: string;
  categoryId?: string;
  userId?: string;
  tenantID?: string;
  merchantID?: string;
  status?: number;
  type?: number;
  isTop?: number;
  level?: string;
  publishAtStart?: string;
  publishAtEnd?: string;
  expireAtStart?: string;
  expireAtEnd?: string;
}

/** 文章创建参数 */
export interface ArticleCreateParams {
  categoryId: string;
  userId: string;
  title: string;
  orderNo: string;
  cover?: string;
  attachmentFile?: string;
  bodyContent?: string;
  extraJSON?: string;
  linkURL?: string;
  status?: number;
  type?: number;
  isTop?: number;
  price?: number;
  payPassword?: string;
  sort?: number;
  icon?: string;
  email?: string;
  phone?: string;
  remark?: string;
  level?: string;
  extraField?: string;
  publishAt?: string;
  expireAt?: string;
  tenantID?: string;
  merchantID?: string;
}

/** 文章更新参数 */
export interface ArticleUpdateParams {
  id: string;
  categoryId: string;
  userId: string;
  title: string;
  orderNo: string;
  cover?: string;
  attachmentFile?: string;
  bodyContent?: string;
  extraJSON?: string;
  linkURL?: string;
  status?: number;
  type?: number;
  isTop?: number;
  price?: number;
  payPassword?: string;
  sort?: number;
  icon?: string;
  email?: string;
  phone?: string;
  remark?: string;
  level?: string;
  extraField?: string;
  publishAt?: string;
  expireAt?: string;
  tenantID?: string;
  merchantID?: string;
}
