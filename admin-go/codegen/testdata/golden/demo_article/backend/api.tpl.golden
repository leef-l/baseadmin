package v1

import (
	"github.com/gogf/gf/v2/frame/g"
	"github.com/gogf/gf/v2/os/gtime"

	"gbaseadmin/app/demo/internal/model"
	"gbaseadmin/utility/snowflake"
)

// 确保 gtime 被引用
var _ = gtime.New

// Article API

// ArticleCreateReq 创建文章请求
type ArticleCreateReq struct {
	g.Meta `path:"/article/create" method:"post" tags:"文章" summary:"创建文章"`
	CategoryID snowflake.JsonInt64 `json:"categoryId" v:"required" dc:"CategoryID"`
	UserID snowflake.JsonInt64 `json:"userId" v:"required" dc:"UserID"`
	Title string `json:"title" v:"required|max-length:200" dc:"Title"`
	OrderNo string `json:"orderNo" v:"required|max-length:50" dc:"OrderNo"`
	Cover string `json:"cover"  dc:"Cover"`
	AttachmentFile string `json:"attachmentFile"  dc:"AttachmentFile"`
	BodyContent string `json:"bodyContent"  dc:"BodyContent"`
	ExtraJSON string `json:"extraJSON"  dc:"ExtraJSON"`
	LinkURL string `json:"linkURL" v:"url|max-length:500" dc:"LinkURL"`
	Status int `json:"status"  dc:"Status"`
	Type int `json:"type"  dc:"Type"`
	IsTop int `json:"isTop"  dc:"IsTop"`
	Price int `json:"price"  dc:"Price"`
	PayPassword string `json:"payPassword" v:"length:6,32" dc:"PayPassword"`
	Sort int `json:"sort"  dc:"Sort"`
	Icon string `json:"icon"  dc:"Icon"`
	Email string `json:"email" v:"email|max-length:100" dc:"Email"`
	Phone string `json:"phone" v:"phone-loose|max-length:20" dc:"Phone"`
	Remark string `json:"remark"  dc:"Remark"`
	Level string `json:"level"  dc:"Level"`
	ExtraField string `json:"extraField"  dc:"ExtraField"`
	PublishAt *gtime.Time `json:"publishAt"  dc:"PublishAt"`
	ExpireAt *gtime.Time `json:"expireAt"  dc:"ExpireAt"`
}

// ArticleCreateRes 创建文章响应
type ArticleCreateRes struct {
	g.Meta `mime:"application/json"`
}

// ArticleUpdateReq 更新文章请求
type ArticleUpdateReq struct {
	g.Meta `path:"/article/update" method:"put" tags:"文章" summary:"更新文章"`
	ID     snowflake.JsonInt64 `json:"id" v:"required#ID不能为空" dc:"文章ID"`
	CategoryID snowflake.JsonInt64 `json:"categoryId"  dc:"CategoryID"`
	UserID snowflake.JsonInt64 `json:"userId"  dc:"UserID"`
	Title string `json:"title" v:"max-length:200" dc:"Title"`
	OrderNo string `json:"orderNo" v:"max-length:50" dc:"OrderNo"`
	Cover string `json:"cover"  dc:"Cover"`
	AttachmentFile string `json:"attachmentFile"  dc:"AttachmentFile"`
	BodyContent string `json:"bodyContent"  dc:"BodyContent"`
	ExtraJSON string `json:"extraJSON"  dc:"ExtraJSON"`
	LinkURL string `json:"linkURL" v:"url|max-length:500" dc:"LinkURL"`
	Status int `json:"status"  dc:"Status"`
	Type int `json:"type"  dc:"Type"`
	IsTop int `json:"isTop"  dc:"IsTop"`
	Price int `json:"price"  dc:"Price"`
	PayPassword string `json:"payPassword" v:"length:6,32" dc:"PayPassword"`
	Sort int `json:"sort"  dc:"Sort"`
	Icon string `json:"icon"  dc:"Icon"`
	Email string `json:"email" v:"email|max-length:100" dc:"Email"`
	Phone string `json:"phone" v:"phone-loose|max-length:20" dc:"Phone"`
	Remark string `json:"remark"  dc:"Remark"`
	Level string `json:"level"  dc:"Level"`
	ExtraField string `json:"extraField"  dc:"ExtraField"`
	PublishAt *gtime.Time `json:"publishAt"  dc:"PublishAt"`
	ExpireAt *gtime.Time `json:"expireAt"  dc:"ExpireAt"`
}

// ArticleUpdateRes 更新文章响应
type ArticleUpdateRes struct {
	g.Meta `mime:"application/json"`
}

// ArticleDeleteReq 删除文章请求
type ArticleDeleteReq struct {
	g.Meta `path:"/article/delete" method:"delete" tags:"文章" summary:"删除文章"`
	ID     snowflake.JsonInt64 `json:"id" v:"required#ID不能为空" dc:"文章ID"`
}

// ArticleDeleteRes 删除文章响应
type ArticleDeleteRes struct {
	g.Meta `mime:"application/json"`
}

// ArticleBatchDeleteReq 批量删除文章请求
type ArticleBatchDeleteReq struct {
	g.Meta `path:"/article/batch-delete" method:"delete" tags:"文章" summary:"批量删除文章"`
	IDs    []snowflake.JsonInt64 `json:"ids" v:"required#ID列表不能为空" dc:"文章ID列表"`
}

// ArticleBatchDeleteRes 批量删除文章响应
type ArticleBatchDeleteRes struct {
	g.Meta `mime:"application/json"`
}

// ArticleBatchUpdateReq 批量编辑文章请求
type ArticleBatchUpdateReq struct {
	g.Meta `path:"/article/batch-update" method:"put" tags:"文章" summary:"批量编辑文章"`
	IDs    []snowflake.JsonInt64 `json:"ids" v:"required#ID列表不能为空" dc:"文章ID列表"`
	Status *int `json:"status" dc:"Status"`
	Type *int `json:"type" dc:"Type"`
	IsTop *int `json:"isTop" dc:"IsTop"`
}

// ArticleBatchUpdateRes 批量编辑文章响应
type ArticleBatchUpdateRes struct {
	g.Meta `mime:"application/json"`
}

// ArticleDetailReq 获取文章详情请求
type ArticleDetailReq struct {
	g.Meta `path:"/article/detail" method:"get" tags:"文章" summary:"获取文章详情"`
	ID     snowflake.JsonInt64 `json:"id" v:"required#ID不能为空" dc:"文章ID"`
}

// ArticleDetailRes 获取文章详情响应
type ArticleDetailRes struct {
	g.Meta `mime:"application/json"`
	*model.ArticleDetailOutput
}

// ArticleListReq 获取文章列表请求
type ArticleListReq struct {
	g.Meta    `path:"/article/list" method:"get" tags:"文章" summary:"获取文章列表"`
	PageNum   int    `json:"pageNum" d:"1" dc:"页码"`
	PageSize  int    `json:"pageSize" d:"10" dc:"每页数量"`
	OrderBy   string `json:"orderBy" dc:"排序字段"`
	OrderDir  string `json:"orderDir" d:"desc" dc:"排序方向:asc/desc"`
	StartTime string `json:"startTime" dc:"开始时间"`
	EndTime   string `json:"endTime" dc:"结束时间"`
	Keyword string `json:"keyword" dc:"关键词"`
	OrderNo string `json:"orderNo" dc:"OrderNo"`
	Title string `json:"title" dc:"Title"`
	Email string `json:"email" dc:"Email"`
	CategoryID *snowflake.JsonInt64 `json:"categoryId" dc:"CategoryID"`
	UserID *snowflake.JsonInt64 `json:"userId" dc:"UserID"`
	Status *int `json:"status" dc:"Status"`
	Type *int `json:"type" dc:"Type"`
	IsTop *int `json:"isTop" dc:"IsTop"`
	Level *string `json:"level" dc:"Level"`
	PublishAtStart string `json:"publishAtStart" dc:"PublishAt开始时间"`
	PublishAtEnd string `json:"publishAtEnd" dc:"PublishAt结束时间"`
	ExpireAtStart string `json:"expireAtStart" dc:"ExpireAt开始时间"`
	ExpireAtEnd string `json:"expireAtEnd" dc:"ExpireAt结束时间"`
}

// ArticleListRes 获取文章列表响应
type ArticleListRes struct {
	g.Meta `mime:"application/json"`
	List   []*model.ArticleListOutput `json:"list" dc:"列表数据"`
	Total  int                               `json:"total" dc:"总数"`
}
// ArticleExportReq 导出文章请求
type ArticleExportReq struct {
	g.Meta    `path:"/article/export" method:"get" tags:"文章" summary:"导出文章"`
	OrderBy   string `json:"orderBy" dc:"排序字段"`
	OrderDir  string `json:"orderDir" d:"desc" dc:"排序方向:asc/desc"`
	StartTime string `json:"startTime" dc:"开始时间"`
	EndTime   string `json:"endTime" dc:"结束时间"`
	Keyword string `json:"keyword" dc:"关键词"`
	OrderNo string `json:"orderNo" dc:"OrderNo"`
	Title string `json:"title" dc:"Title"`
	Email string `json:"email" dc:"Email"`
	CategoryID *snowflake.JsonInt64 `json:"categoryId" dc:"CategoryID"`
	UserID *snowflake.JsonInt64 `json:"userId" dc:"UserID"`
	Status *int `json:"status" dc:"Status"`
	Type *int `json:"type" dc:"Type"`
	IsTop *int `json:"isTop" dc:"IsTop"`
	Level *string `json:"level" dc:"Level"`
	PublishAtStart string `json:"publishAtStart" dc:"PublishAt开始时间"`
	PublishAtEnd string `json:"publishAtEnd" dc:"PublishAt结束时间"`
	ExpireAtStart string `json:"expireAtStart" dc:"ExpireAt开始时间"`
	ExpireAtEnd string `json:"expireAtEnd" dc:"ExpireAt结束时间"`
}

// ArticleExportRes 导出文章响应
type ArticleExportRes struct {
	g.Meta `mime:"text/csv"`
}

// ArticleImportReq 导入文章请求
type ArticleImportReq struct {
	g.Meta `path:"/article/import" method:"post" mime:"multipart/form-data" tags:"文章" summary:"导入文章"`
}

// ArticleImportRes 导入文章响应
type ArticleImportRes struct {
	g.Meta  `mime:"application/json"`
	Success int `json:"success" dc:"成功条数"`
	Fail    int `json:"fail" dc:"失败条数"`
}

// ArticleImportTemplateReq 下载文章导入模板
type ArticleImportTemplateReq struct {
	g.Meta `path:"/article/import-template" method:"get" tags:"文章" summary:"下载文章导入模板"`
}

// ArticleImportTemplateRes 下载文章导入模板响应
type ArticleImportTemplateRes struct {
	g.Meta `mime:"text/csv"`
}

