package service

import (
	"context"
	"gbaseadmin/app/demo/internal/model"
	"gbaseadmin/utility/snowflake"
	"github.com/gogf/gf/v2/net/ghttp"
)

type IArticle interface {
	Create(ctx context.Context, in *model.ArticleCreateInput) error
	Update(ctx context.Context, in *model.ArticleUpdateInput) error
	Delete(ctx context.Context, id snowflake.JsonInt64) error
	BatchDelete(ctx context.Context, ids []snowflake.JsonInt64) error
	Detail(ctx context.Context, id snowflake.JsonInt64) (out *model.ArticleDetailOutput, err error)
	List(ctx context.Context, in *model.ArticleListInput) (list []*model.ArticleListOutput, total int, err error)
	Export(ctx context.Context, in *model.ArticleListInput) (list []*model.ArticleListOutput, err error)
	BatchUpdate(ctx context.Context, in *model.ArticleBatchUpdateInput) error
	Import(ctx context.Context, file *ghttp.UploadFile) (success int, fail int, err error)
}

var localArticle IArticle

func Article() IArticle {
	return localArticle
}

func RegisterArticle(i IArticle) {
	localArticle = i
}
