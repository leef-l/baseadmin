// List 获取文章列表
func (c *cArticle) List(ctx context.Context, req *v1.ArticleListReq) (res *v1.ArticleListRes, err error) {
	res = &v1.ArticleListRes{}
	res.List, res.Total, err = service.Article().List(ctx, &model.ArticleListInput{
		PageNum:   req.PageNum,
		PageSize:  req.PageSize,
		OrderBy:   req.OrderBy,
		OrderDir:  req.OrderDir,
		StartTime: req.StartTime,
		EndTime:   req.EndTime,
		Keyword: req.Keyword,
		OrderNo: req.OrderNo,
		Title: req.Title,
		Email: req.Email,
		CategoryID: req.CategoryID,
		UserID: req.UserID,
		TenantID: req.TenantID,
		MerchantID: req.MerchantID,
		Status: req.Status,
		Type: req.Type,
		IsTop: req.IsTop,
		Level: req.Level,
		PublishAtStart: req.PublishAtStart,
		PublishAtEnd: req.PublishAtEnd,
		ExpireAtStart: req.ExpireAtStart,
		ExpireAtEnd: req.ExpireAtEnd,
	})
	return
}
// Export 导出文章
func (c *cArticle) Export(ctx context.Context, req *v1.ArticleExportReq) (res *v1.ArticleExportRes, err error) {
	list, err := service.Article().Export(ctx, &model.ArticleListInput{
		OrderBy:   req.OrderBy,
		OrderDir:  req.OrderDir,
		StartTime: req.StartTime,
		EndTime:   req.EndTime,
		Keyword: req.Keyword,
		OrderNo: req.OrderNo,
		Title: req.Title,
		Email: req.Email,
		CategoryID: req.CategoryID,
		UserID: req.UserID,
		TenantID: req.TenantID,
		MerchantID: req.MerchantID,
		Status: req.Status,
		Type: req.Type,
		IsTop: req.IsTop,
		Level: req.Level,
		PublishAtStart: req.PublishAtStart,
		PublishAtEnd: req.PublishAtEnd,
		ExpireAtStart: req.ExpireAtStart,
		ExpireAtEnd: req.ExpireAtEnd,
	})
	if err != nil {
		return
	}
	// CSV 导出（使用 csv.Writer 防止注入和格式问题）
	r := g.RequestFromCtx(ctx)
	r.Response.Header().Set("Content-Type", "text/csv; charset=utf-8")
	r.Response.Header().Set("Content-Disposition", `attachment; filename="article.csv"`)
	r.Response.Write("\xEF\xBB\xBF") // UTF-8 BOM
	w := csv.NewWriter(r.Response.Writer)
	// 表头
	_ = w.Write([]string{"CategoryID", "UserID", "Title", "OrderNo", "Cover", "AttachmentFile", "BodyContent", "ExtraJSON", "LinkURL", "Status", "Type", "IsTop", "Price", "Sort", "Icon", "Email", "Phone", "Remark", "Level", "ExtraField", "PublishAt", "ExpireAt", "租户", "商户", "创建时间"})
	// 数据行
	for _, item := range list {
		_ = w.Write([]string{
			csvSafeArticle(item.CategoryName),
			csvSafeArticle(item.UsersUsername),
			csvSafeArticle(item.Title),
			csvSafeArticle(item.OrderNo),
			csvSafeArticle(item.Cover),
			csvSafeArticle(item.AttachmentFile),
			csvSafeArticle(item.BodyContent),
			csvSafeArticle(item.ExtraJSON),
			csvSafeArticle(item.LinkURL),
			fmt.Sprintf("%v", item.Status),
			fmt.Sprintf("%v", item.Type),
			fmt.Sprintf("%v", item.IsTop),
			fmt.Sprintf("%.2f", float64(item.Price)/100),
			fmt.Sprintf("%v", item.Sort),
			csvSafeArticle(item.Icon),
			csvSafeArticle(item.Email),
			csvSafeArticle(item.Phone),
			csvSafeArticle(item.Remark),
			csvSafeArticle(item.Level),
			csvSafeArticle(item.ExtraField),
			func() string { if item.PublishAt != nil { return item.PublishAt.String() }; return "" }(),
			func() string { if item.ExpireAt != nil { return item.ExpireAt.String() }; return "" }(),
			csvSafeArticle(item.TenantName),
			csvSafeArticle(item.MerchantName),
			func() string { if item.CreatedAt != nil { return item.CreatedAt.String() }; return "" }(),
		})
	}
	w.Flush()
	return
}

// Import 导入文章
func (c *cArticle) Import(ctx context.Context, req *v1.ArticleImportReq) (res *v1.ArticleImportRes, err error) {
	r := g.RequestFromCtx(ctx)
	file := r.GetUploadFile("file")
	if file == nil {
		return nil, fmt.Errorf("请上传文件")
	}
	success, fail, err := service.Article().Import(ctx, file)
	if err != nil {
		return nil, err
	}
	res = &v1.ArticleImportRes{Success: success, Fail: fail}
	return
}

// ImportTemplate 下载文章导入模板
func (c *cArticle) ImportTemplate(ctx context.Context, req *v1.ArticleImportTemplateReq) (res *v1.ArticleImportTemplateRes, err error) {
	r := g.RequestFromCtx(ctx)
	r.Response.Header().Set("Content-Type", "text/csv; charset=utf-8")
	r.Response.Header().Set("Content-Disposition", `attachment; filename="article_template.csv"`)
	r.Response.Write("\xEF\xBB\xBF") // UTF-8 BOM
	w := csv.NewWriter(r.Response.Writer)
	_ = w.Write([]string{"CategoryID", "UserID", "Title", "OrderNo", "Cover", "AttachmentFile", "BodyContent", "ExtraJSON", "LinkURL", "Status", "Type", "IsTop", "Price", "Sort", "Icon", "Email", "Phone", "Remark", "Level", "ExtraField"})
	w.Flush()
	return
}
