// BatchDelete 批量删除文章
func (c *cArticle) BatchDelete(ctx context.Context, req *v1.ArticleBatchDeleteReq) (res *v1.ArticleBatchDeleteRes, err error) {
	err = service.Article().BatchDelete(ctx, req.IDs)
	return
}

// BatchUpdate 批量编辑文章
func (c *cArticle) BatchUpdate(ctx context.Context, req *v1.ArticleBatchUpdateReq) (res *v1.ArticleBatchUpdateRes, err error) {
	err = service.Article().BatchUpdate(ctx, &model.ArticleBatchUpdateInput{
