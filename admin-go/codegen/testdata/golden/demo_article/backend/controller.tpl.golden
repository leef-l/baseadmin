// Detail 获取文章详情
func (c *cArticle) Detail(ctx context.Context, req *v1.ArticleDetailReq) (res *v1.ArticleDetailRes, err error) {
	res = &v1.ArticleDetailRes{}
	res.ArticleDetailOutput, err = service.Article().Detail(ctx, req.ID)
