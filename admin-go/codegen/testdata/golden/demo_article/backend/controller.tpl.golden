package article

import (
	"context"
	"encoding/csv"
	"fmt"
	"strings"

	"github.com/gogf/gf/v2/frame/g"

	v1 "gbaseadmin/app/demo/api/demo/v1"
	"gbaseadmin/app/demo/internal/model"
	"gbaseadmin/app/demo/internal/service"
)

func csvSafeArticle(s string) string {
	if len(s) == 0 {
		return s
	}
	if s[0] == 0 || strings.ContainsAny(s[:1], "=+-@\t\r") {
		return "'" + s
	}
	return s
}

var Article = cArticle{}

type cArticle struct{}

// Create 创建文章
func (c *cArticle) Create(ctx context.Context, req *v1.ArticleCreateReq) (res *v1.ArticleCreateRes, err error) {
	err = service.Article().Create(ctx, &model.ArticleCreateInput{
		CategoryID: req.CategoryID,
		UserID: req.UserID,
		Title: req.Title,
		OrderNo: req.OrderNo,
		Cover: req.Cover,
		AttachmentFile: req.AttachmentFile,
		BodyContent: req.BodyContent,
		ExtraJSON: req.ExtraJSON,
		LinkURL: req.LinkURL,
		Status: req.Status,
		Type: req.Type,
		IsTop: req.IsTop,
		Price: req.Price,
		PayPassword: req.PayPassword,
		Sort: req.Sort,
		Icon: req.Icon,
		Email: req.Email,
		Phone: req.Phone,
		Remark: req.Remark,
		Level: req.Level,
		ExtraField: req.ExtraField,
		PublishAt: req.PublishAt,
		ExpireAt: req.ExpireAt,
		TenantID: req.TenantID,
		MerchantID: req.MerchantID,
	})
	return
}

