
package user_review

import (
	"context"
	"encoding/csv"
	"io"
	"strconv"
	"strings"
	"fmt"

	"github.com/gogf/gf/v2/database/gdb"
	"github.com/gogf/gf/v2/errors/gerror"
	"github.com/gogf/gf/v2/frame/g"
	"github.com/gogf/gf/v2/net/ghttp"

	"gbaseadmin/app/demo/internal/dao"
	"gbaseadmin/app/demo/internal/middleware"
	"gbaseadmin/app/demo/internal/model"
	"gbaseadmin/app/demo/internal/model/do"
	"gbaseadmin/app/demo/internal/service"
	"gbaseadmin/utility/snowflake"
)

func init() {
	service.RegisterUserReview(New())
}

func New() *sUserReview {
	return &sUserReview{}
}

type sUserReview struct{}

func normalizeUserReviewIDs(ids []snowflake.JsonInt64) []snowflake.JsonInt64 {
	if len(ids) == 0 {
		return nil
	}
	seen := make(map[int64]struct{}, len(ids))
	normalized := make([]snowflake.JsonInt64, 0, len(ids))
	for _, id := range ids {
		value := int64(id)
		if value <= 0 {
			continue
		}
		if _, ok := seen[value]; ok {
			continue
		}
		seen[value] = struct{}{}
		normalized = append(normalized, id)
		if len(normalized) >= 500 {
			break
		}
	}
	if len(normalized) == 0 {
		return nil
	}
	return normalized
}

// Create 创建用户审核
func (s *sUserReview) Create(ctx context.Context, in *model.UserReviewCreateInput) error {
	id := snowflake.Generate()
	middleware.ApplyTenantScopeToWrite(ctx, &in.TenantID, &in.MerchantID)
	if err := middleware.EnsureTenantMerchantAccessible(ctx, in.TenantID, in.MerchantID); err != nil {
		return err
	}
	_, err := dao.DemoUserReview.Ctx(ctx).Data(do.DemoUserReview{
		Id:        id,
		UserId: in.UserID,
		ReviewType: in.ReviewType,
		Content: in.Content,
		Score: in.Score,
		IsPassed: in.IsPassed,
		Sort: in.Sort,
		Status: in.Status,
		TenantId: in.TenantID,
		MerchantId: in.MerchantID,
		CreatedBy: middleware.GetUserID(ctx),
		DeptId: middleware.GetDeptID(ctx),
	}).Insert()
	return err
}

// Update 更新用户审核
func (s *sUserReview) Update(ctx context.Context, in *model.UserReviewUpdateInput) error {
	middleware.ApplyTenantScopeToWrite(ctx, &in.TenantID, &in.MerchantID)
	if err := middleware.EnsureTenantMerchantAccessible(ctx, in.TenantID, in.MerchantID); err != nil {
		return err
	}
	data := do.DemoUserReview{
		UserId: in.UserID,
		ReviewType: in.ReviewType,
		Content: in.Content,
		Score: in.Score,
		IsPassed: in.IsPassed,
		Sort: in.Sort,
		Status: in.Status,
	}
	if err := middleware.EnsureTenantScopedRowAccessible(ctx, dao.DemoUserReview.Ctx(ctx), in.ID, dao.DemoUserReview.Columns().Id, dao.DemoUserReview.Columns().TenantId, dao.DemoUserReview.Columns().MerchantId, "用户审核"); err != nil {
		return err
	}
	if err := middleware.EnsureDataScopedRowAccessible(ctx, dao.DemoUserReview.Ctx(ctx), in.ID, dao.DemoUserReview.Columns().Id, dao.DemoUserReview.Columns().CreatedBy, dao.DemoUserReview.Columns().DeptId); err != nil {
		return err
	}
	_, err := dao.DemoUserReview.Ctx(ctx).Where(dao.DemoUserReview.Columns().Id, in.ID).Where(dao.DemoUserReview.Columns().DeletedAt, nil).Data(data).Update()
	return err
}

// Delete 软删除用户审核
func (s *sUserReview) Delete(ctx context.Context, id snowflake.JsonInt64) error {
	if err := middleware.EnsureTenantScopedRowAccessible(ctx, dao.DemoUserReview.Ctx(ctx), id, dao.DemoUserReview.Columns().Id, dao.DemoUserReview.Columns().TenantId, dao.DemoUserReview.Columns().MerchantId, "用户审核"); err != nil {
		return err
	}
	if err := middleware.EnsureDataScopedRowAccessible(ctx, dao.DemoUserReview.Ctx(ctx), id, dao.DemoUserReview.Columns().Id, dao.DemoUserReview.Columns().CreatedBy, dao.DemoUserReview.Columns().DeptId); err != nil {
		return err
	}
	_, err := dao.DemoUserReview.Ctx(ctx).Where(dao.DemoUserReview.Columns().Id, id).Delete()
	return err
}

// BatchDelete 批量软删除用户审核
func (s *sUserReview) BatchDelete(ctx context.Context, ids []snowflake.JsonInt64) error {
	normalizedIDs := normalizeUserReviewIDs(ids)
	if len(normalizedIDs) == 0 {
		return nil
	}
	if err := middleware.EnsureTenantScopedRowsAccessible(ctx, dao.DemoUserReview.Ctx(ctx), normalizedIDs, dao.DemoUserReview.Columns().Id, dao.DemoUserReview.Columns().TenantId, dao.DemoUserReview.Columns().MerchantId, "用户审核"); err != nil {
		return err
	}
	if err := middleware.EnsureDataScopedRowsAccessible(ctx, dao.DemoUserReview.Ctx(ctx), normalizedIDs, dao.DemoUserReview.Columns().Id, dao.DemoUserReview.Columns().CreatedBy, dao.DemoUserReview.Columns().DeptId); err != nil {
		return err
	}
	_, err := dao.DemoUserReview.Ctx(ctx).WhereIn(dao.DemoUserReview.Columns().Id, normalizedIDs).Delete()
	return err
}

// Detail 获取用户审核详情
func (s *sUserReview) Detail(ctx context.Context, id snowflake.JsonInt64) (out *model.UserReviewDetailOutput, err error) {
	if err = middleware.EnsureTenantScopedRowAccessible(ctx, dao.DemoUserReview.Ctx(ctx), id, dao.DemoUserReview.Columns().Id, dao.DemoUserReview.Columns().TenantId, dao.DemoUserReview.Columns().MerchantId, "用户审核"); err != nil {
		return nil, err
	}
	if err = middleware.EnsureDataScopedRowAccessible(ctx, dao.DemoUserReview.Ctx(ctx), id, dao.DemoUserReview.Columns().Id, dao.DemoUserReview.Columns().CreatedBy, dao.DemoUserReview.Columns().DeptId); err != nil {
		return nil, err
	}
	out = &model.UserReviewDetailOutput{}
	err = dao.DemoUserReview.Ctx(ctx).Where(dao.DemoUserReview.Columns().Id, id).Where(dao.DemoUserReview.Columns().DeletedAt, nil).Scan(out)
	if err != nil {
		return nil, err
	}
	if out == nil || out.ID == 0 {
		return nil, gerror.New("用户审核不存在或已删除")
	}
	// 查询UserID关联显示
	if out.UserID != 0 {
		refQuery := g.DB().Ctx(ctx).Model("system_users").Where("id", out.UserID)
		refQuery = refQuery.Where("deleted_at", nil)
		val, err := refQuery.Value("username")
		if err == nil {
			out.UsersUsername = val.String()
		}
	}
	// 查询租户关联显示
	if out.TenantID != 0 {
		refQuery := g.DB().Ctx(ctx).Model("system_tenant").Where("id", out.TenantID)
		val, err := refQuery.Value("name")
		if err == nil {
			out.TenantName = val.String()
		}
	}
	// 查询商户关联显示
	if out.MerchantID != 0 {
		refQuery := g.DB().Ctx(ctx).Model("system_merchant").Where("id", out.MerchantID)
		val, err := refQuery.Value("name")
		if err == nil {
			out.MerchantName = val.String()
		}
	}
	return
}

// applyListFilter 应用列表通用过滤条件
func (s *sUserReview) applyListFilter(ctx context.Context, in *model.UserReviewListInput) *gdb.Model {
	m := dao.DemoUserReview.Ctx(ctx).Where(dao.DemoUserReview.Columns().DeletedAt, nil)
	m = middleware.ApplyTenantScopeToModel(ctx, m, dao.DemoUserReview.Columns().TenantId, dao.DemoUserReview.Columns().MerchantId)
	if in.UserID != nil {
		m = m.Where(dao.DemoUserReview.Columns().UserId, *in.UserID)
	}
	if in.TenantID != nil {
		m = m.Where(dao.DemoUserReview.Columns().TenantId, *in.TenantID)
	}
	if in.MerchantID != nil {
		m = m.Where(dao.DemoUserReview.Columns().MerchantId, *in.MerchantID)
	}
	if in.ReviewType != nil {
		m = m.Where(dao.DemoUserReview.Columns().ReviewType, *in.ReviewType)
	}
	if in.IsPassed != nil {
		m = m.Where(dao.DemoUserReview.Columns().IsPassed, *in.IsPassed)
	}
	if in.Status != nil {
		m = m.Where(dao.DemoUserReview.Columns().Status, *in.Status)
	}
	if in.Content != "" {
		m = m.WhereLike(dao.DemoUserReview.Columns().Content, "%"+in.Content+"%")
	}
	if in.StartTime != "" {
		m = m.WhereGTE(dao.DemoUserReview.Columns().CreatedAt, in.StartTime)
	}
	if in.EndTime != "" {
		m = m.WhereLTE(dao.DemoUserReview.Columns().CreatedAt, in.EndTime)
	}
	// 数据权限过滤
	m = middleware.ApplyDataScope(ctx, m, dao.DemoUserReview.Columns().CreatedBy, dao.DemoUserReview.Columns().DeptId)
	return m
}

// fillRefFields 批量填充关联显示字段（避免 N+1 查询）
func (s *sUserReview) fillRefFields(ctx context.Context, list []*model.UserReviewListOutput) {
	{
		idSet := make(map[int64]struct{})
		for _, item := range list {
			if item.UserID != 0 {
				idSet[int64(item.UserID)] = struct{}{}
			}
		}
		if len(idSet) > 0 {
			ids := make([]int64, 0, len(idSet))
			for id := range idSet {
				ids = append(ids, id)
			}
			refQuery := g.DB().Ctx(ctx).Model("system_users").
				Fields("id", "username")
			refQuery = refQuery.Where("deleted_at", nil)
			rows, err := refQuery.WhereIn("id", ids).All()
			if err == nil {
				refMap := make(map[int64]string, len(rows))
				for _, row := range rows {
					refMap[row["id"].Int64()] = row["username"].String()
				}
				for _, item := range list {
					if val, ok := refMap[int64(item.UserID)]; ok {
						item.UsersUsername = val
					}
				}
			}
		}
	}
	{
		idSet := make(map[int64]struct{})
		for _, item := range list {
			if item.TenantID != 0 {
				idSet[int64(item.TenantID)] = struct{}{}
			}
		}
		if len(idSet) > 0 {
			ids := make([]int64, 0, len(idSet))
			for id := range idSet {
				ids = append(ids, id)
			}
			refQuery := g.DB().Ctx(ctx).Model("system_tenant").
				Fields("id", "name")
			rows, err := refQuery.WhereIn("id", ids).All()
			if err == nil {
				refMap := make(map[int64]string, len(rows))
				for _, row := range rows {
					refMap[row["id"].Int64()] = row["name"].String()
				}
				for _, item := range list {
					if val, ok := refMap[int64(item.TenantID)]; ok {
						item.TenantName = val
					}
				}
			}
		}
	}
	{
		idSet := make(map[int64]struct{})
		for _, item := range list {
			if item.MerchantID != 0 {
				idSet[int64(item.MerchantID)] = struct{}{}
			}
		}
		if len(idSet) > 0 {
			ids := make([]int64, 0, len(idSet))
			for id := range idSet {
				ids = append(ids, id)
			}
			refQuery := g.DB().Ctx(ctx).Model("system_merchant").
				Fields("id", "name")
			rows, err := refQuery.WhereIn("id", ids).All()
			if err == nil {
				refMap := make(map[int64]string, len(rows))
				for _, row := range rows {
					refMap[row["id"].Int64()] = row["name"].String()
				}
				for _, item := range list {
					if val, ok := refMap[int64(item.MerchantID)]; ok {
						item.MerchantName = val
					}
				}
			}
		}
	}
}

// List 获取用户审核列表
func (s *sUserReview) List(ctx context.Context, in *model.UserReviewListInput) (list []*model.UserReviewListOutput, total int, err error) {
	if in == nil {
		in = &model.UserReviewListInput{}
	}
	// PageSize 上限保护
	if in.PageSize <= 0 {
		in.PageSize = 10
	} else if in.PageSize > 500 {
		in.PageSize = 500
	}
	if in.PageNum <= 0 {
		in.PageNum = 1
	}
	m := s.applyListFilter(ctx, in)
	total, err = m.Count()
	if err != nil {
		return
	}
	// 动态排序（白名单校验防止 SQL 注入）
	m = s.applyListOrder(m, in.OrderBy, in.OrderDir)
	err = m.Page(in.PageNum, in.PageSize).Scan(&list)
	if err != nil {
		return
	}
	s.fillRefFields(ctx, list)
	return
}

// isAllowedOrderField 校验排序字段是否在允许列表中
func (s *sUserReview) isAllowedOrderField(field string) bool {
	allowed := map[string]bool{
		dao.DemoUserReview.Columns().Id:        true,
		dao.DemoUserReview.Columns().CreatedAt: true,
		dao.DemoUserReview.Columns().Sort:      true,
		dao.DemoUserReview.Columns().Status:    true,
		dao.DemoUserReview.Columns().Content: true,
	}
	return allowed[field]
}

func (s *sUserReview) applyListOrder(m *gdb.Model, orderBy, orderDir string) *gdb.Model {
	if orderBy != "" && s.isAllowedOrderField(orderBy) {
		if orderDir == "desc" {
			return m.OrderDesc(orderBy)
		}
		return m.OrderAsc(orderBy)
	}
	return m.OrderAsc(dao.DemoUserReview.Columns().Sort).OrderDesc(dao.DemoUserReview.Columns().Id)
}

// Export 导出用户审核（不分页）
func (s *sUserReview) Export(ctx context.Context, in *model.UserReviewListInput) (list []*model.UserReviewListOutput, err error) {
	if in == nil {
		in = &model.UserReviewListInput{}
	}
	m := s.applyListFilter(ctx, in)
	err = s.applyListOrder(m, in.OrderBy, in.OrderDir).Limit(10000).Scan(&list)
	if err != nil {
		return
	}
	s.fillRefFields(ctx, list)
	return
}

// BatchUpdate 批量编辑用户审核
func (s *sUserReview) BatchUpdate(ctx context.Context, in *model.UserReviewBatchUpdateInput) error {
	data := do.DemoUserReview{}
	hasChange := false
	if in.ReviewType != nil {
		data.ReviewType = *in.ReviewType
		hasChange = true
	}
	if in.IsPassed != nil {
		data.IsPassed = *in.IsPassed
		hasChange = true
	}
	if in.Status != nil {
		data.Status = *in.Status
		hasChange = true
	}
	if !hasChange {
		return nil
	}
	normalizedIDs := normalizeUserReviewIDs(in.IDs)
	if len(normalizedIDs) == 0 {
		return nil
	}
	if err := middleware.EnsureTenantScopedRowsAccessible(ctx, dao.DemoUserReview.Ctx(ctx), normalizedIDs, dao.DemoUserReview.Columns().Id, dao.DemoUserReview.Columns().TenantId, dao.DemoUserReview.Columns().MerchantId, "用户审核"); err != nil {
		return err
	}
	if err := middleware.EnsureDataScopedRowsAccessible(ctx, dao.DemoUserReview.Ctx(ctx), normalizedIDs, dao.DemoUserReview.Columns().Id, dao.DemoUserReview.Columns().CreatedBy, dao.DemoUserReview.Columns().DeptId); err != nil {
		return err
	}
	_, err := dao.DemoUserReview.Ctx(ctx).WhereIn(dao.DemoUserReview.Columns().Id, normalizedIDs).Data(data).Update()
	return err
}

// Import 导入用户审核
func (s *sUserReview) Import(ctx context.Context, file *ghttp.UploadFile) (success int, fail int, err error) {
	const maxImportFileSize = 10 << 20 // 10MB
	const maxImportRows = 5000
	if file.Size > maxImportFileSize {
		return 0, 0, fmt.Errorf("文件大小超过限制（最大10MB）")
	}
	f, err := file.Open()
	if err != nil {
		return 0, 0, err
	}
	defer f.Close()

	reader := csv.NewReader(f)
	// 跳过表头
	if _, err = reader.Read(); err != nil {
		return 0, 0, fmt.Errorf("读取CSV表头失败: %w", err)
	}

	rowCount := 0
	for {
		record, readErr := reader.Read()
		if readErr != nil {
			if readErr == io.EOF {
				break
			}
			return success, fail, fmt.Errorf("读取CSV数据失败: %w", readErr)
		}
		if len(record) == 0 {
			continue
		}
		rowCount++
		if rowCount > maxImportRows {
			return success, fail, fmt.Errorf("导入数据超过 %d 行上限，已处理 %d 条成功、%d 条失败", maxImportRows, success, fail)
		}
		// 逐行插入
		id := snowflake.Generate()
		data := do.DemoUserReview{
			Id: id,
			CreatedBy: middleware.GetUserID(ctx),
			DeptId: middleware.GetDeptID(ctx),
		}
		idx := 0
		if idx < len(record) {
			if v, parseErr := strconv.ParseInt(strings.TrimSpace(record[idx]), 10, 64); parseErr == nil {
				data.UserId = v
			}
		}
		idx++
		if idx < len(record) {
			if v, parseErr := strconv.Atoi(strings.TrimSpace(record[idx])); parseErr == nil {
				data.ReviewType = v
			}
		}
		idx++
		if idx < len(record) {
			data.Content = strings.TrimSpace(record[idx])
		}
		idx++
		if idx < len(record) {
			if v, parseErr := strconv.Atoi(strings.TrimSpace(record[idx])); parseErr == nil {
				data.Score = v
			}
		}
		idx++
		if idx < len(record) {
			if v, parseErr := strconv.Atoi(strings.TrimSpace(record[idx])); parseErr == nil {
				data.IsPassed = v
			}
		}
		idx++
		if idx < len(record) {
			if v, parseErr := strconv.Atoi(strings.TrimSpace(record[idx])); parseErr == nil {
				data.Sort = v
			}
		}
		idx++
		if idx < len(record) {
			if v, parseErr := strconv.Atoi(strings.TrimSpace(record[idx])); parseErr == nil {
				data.Status = v
			}
		}
		idx++
		tenantID := snowflake.JsonInt64(0)
		merchantID := snowflake.JsonInt64(0)
		middleware.ApplyTenantScopeToWrite(ctx, &tenantID, &merchantID)
		if err := middleware.EnsureTenantMerchantAccessible(ctx, tenantID, merchantID); err != nil {
			fail++
			continue
		}
		data.TenantId = tenantID
		data.MerchantId = merchantID
		if fkVal, ok := data.UserId.(int64); ok && fkVal > 0 {
			refQuery := g.DB().Ctx(ctx).Model("system_users").Where("id", fkVal)
			refQuery = refQuery.Where("deleted_at", nil)
			if cnt, cntErr := refQuery.Count(); cntErr != nil || cnt == 0 {
				fail++
				continue
			}
		}
		if _, insertErr := dao.DemoUserReview.Ctx(ctx).Data(data).Insert(); insertErr != nil {
			fail++
		} else {
			success++
		}
	}
	return
}

