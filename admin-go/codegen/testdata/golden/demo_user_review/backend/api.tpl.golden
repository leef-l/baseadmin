package v1

import (
	"github.com/gogf/gf/v2/frame/g"
	"github.com/gogf/gf/v2/os/gtime"

	"gbaseadmin/app/demo/internal/model"
	"gbaseadmin/utility/snowflake"
)

// 确保 gtime 被引用
var _ = gtime.New

// UserReview API

// UserReviewCreateReq 创建用户审核请求
type UserReviewCreateReq struct {
	g.Meta `path:"/user_review/create" method:"post" tags:"用户审核" summary:"创建用户审核"`
	UserID snowflake.JsonInt64 `json:"userId" v:"required" dc:"UserID"`
	ReviewType int `json:"reviewType"  dc:"ReviewType"`
	Content string `json:"content" v:"max-length:500" dc:"Content"`
	Score int `json:"score"  dc:"Score"`
	IsPassed int `json:"isPassed"  dc:"IsPassed"`
	Sort int `json:"sort"  dc:"Sort"`
	Status int `json:"status"  dc:"Status"`
	TenantID snowflake.JsonInt64 `json:"tenantID"  dc:"租户"`
	MerchantID snowflake.JsonInt64 `json:"merchantID"  dc:"商户"`
}

// UserReviewCreateRes 创建用户审核响应
type UserReviewCreateRes struct {
	g.Meta `mime:"application/json"`
}

// UserReviewUpdateReq 更新用户审核请求
type UserReviewUpdateReq struct {
	g.Meta `path:"/user_review/update" method:"put" tags:"用户审核" summary:"更新用户审核"`
	ID     snowflake.JsonInt64 `json:"id" v:"required#ID不能为空" dc:"用户审核ID"`
	UserID snowflake.JsonInt64 `json:"userId"  dc:"UserID"`
	ReviewType int `json:"reviewType"  dc:"ReviewType"`
	Content string `json:"content" v:"max-length:500" dc:"Content"`
	Score int `json:"score"  dc:"Score"`
	IsPassed int `json:"isPassed"  dc:"IsPassed"`
	Sort int `json:"sort"  dc:"Sort"`
	Status int `json:"status"  dc:"Status"`
	TenantID snowflake.JsonInt64 `json:"tenantID"  dc:"租户"`
	MerchantID snowflake.JsonInt64 `json:"merchantID"  dc:"商户"`
}

// UserReviewUpdateRes 更新用户审核响应
type UserReviewUpdateRes struct {
	g.Meta `mime:"application/json"`
}

// UserReviewDeleteReq 删除用户审核请求
type UserReviewDeleteReq struct {
	g.Meta `path:"/user_review/delete" method:"delete" tags:"用户审核" summary:"删除用户审核"`
	ID     snowflake.JsonInt64 `json:"id" v:"required#ID不能为空" dc:"用户审核ID"`
}

// UserReviewDeleteRes 删除用户审核响应
type UserReviewDeleteRes struct {
	g.Meta `mime:"application/json"`
}

// UserReviewBatchDeleteReq 批量删除用户审核请求
type UserReviewBatchDeleteReq struct {
	g.Meta `path:"/user_review/batch-delete" method:"delete" tags:"用户审核" summary:"批量删除用户审核"`
	IDs    []snowflake.JsonInt64 `json:"ids" v:"required|max-length:500#ID列表不能为空|最多支持500条" dc:"用户审核ID列表"`
}

// UserReviewBatchDeleteRes 批量删除用户审核响应
type UserReviewBatchDeleteRes struct {
	g.Meta `mime:"application/json"`
}

// UserReviewBatchUpdateReq 批量编辑用户审核请求
type UserReviewBatchUpdateReq struct {
	g.Meta `path:"/user_review/batch-update" method:"put" tags:"用户审核" summary:"批量编辑用户审核"`
	IDs    []snowflake.JsonInt64 `json:"ids" v:"required|max-length:500#ID列表不能为空|最多支持500条" dc:"用户审核ID列表"`
	ReviewType *int `json:"reviewType" dc:"ReviewType"`
	IsPassed *int `json:"isPassed" dc:"IsPassed"`
	Status *int `json:"status" dc:"Status"`
}

// UserReviewBatchUpdateRes 批量编辑用户审核响应
type UserReviewBatchUpdateRes struct {
	g.Meta `mime:"application/json"`
}

// UserReviewDetailReq 获取用户审核详情请求
type UserReviewDetailReq struct {
	g.Meta `path:"/user_review/detail" method:"get" tags:"用户审核" summary:"获取用户审核详情"`
	ID     snowflake.JsonInt64 `json:"id" v:"required#ID不能为空" dc:"用户审核ID"`
}

// UserReviewDetailRes 获取用户审核详情响应
type UserReviewDetailRes struct {
	g.Meta `mime:"application/json"`
	*model.UserReviewDetailOutput
}

// UserReviewListReq 获取用户审核列表请求
type UserReviewListReq struct {
	g.Meta    `path:"/user_review/list" method:"get" tags:"用户审核" summary:"获取用户审核列表"`
	PageNum   int    `json:"pageNum" d:"1" v:"min:1" dc:"页码"`
	PageSize  int    `json:"pageSize" d:"10" v:"between:1,500" dc:"每页数量"`
	OrderBy   string `json:"orderBy" dc:"排序字段"`
	OrderDir  string `json:"orderDir" d:"desc" v:"in:asc,desc" dc:"排序方向:asc/desc"`
	StartTime string `json:"startTime" dc:"开始时间"`
	EndTime   string `json:"endTime" dc:"结束时间"`
	UserID *snowflake.JsonInt64 `json:"userId" dc:"UserID"`
	TenantID *snowflake.JsonInt64 `json:"tenantID" dc:"租户"`
	MerchantID *snowflake.JsonInt64 `json:"merchantID" dc:"商户"`
	ReviewType *int `json:"reviewType" dc:"ReviewType"`
	IsPassed *int `json:"isPassed" dc:"IsPassed"`
	Status *int `json:"status" dc:"Status"`
	Content string `json:"content" dc:"Content"`
}

// UserReviewListRes 获取用户审核列表响应
type UserReviewListRes struct {
	g.Meta `mime:"application/json"`
	List   []*model.UserReviewListOutput `json:"list" dc:"列表数据"`
	Total  int                               `json:"total" dc:"总数"`
}
// UserReviewExportReq 导出用户审核请求
type UserReviewExportReq struct {
	g.Meta    `path:"/user_review/export" method:"get" tags:"用户审核" summary:"导出用户审核"`
	OrderBy   string `json:"orderBy" dc:"排序字段"`
	OrderDir  string `json:"orderDir" d:"desc" v:"in:asc,desc" dc:"排序方向:asc/desc"`
	StartTime string `json:"startTime" dc:"开始时间"`
	EndTime   string `json:"endTime" dc:"结束时间"`
	UserID *snowflake.JsonInt64 `json:"userId" dc:"UserID"`
	TenantID *snowflake.JsonInt64 `json:"tenantID" dc:"租户"`
	MerchantID *snowflake.JsonInt64 `json:"merchantID" dc:"商户"`
	ReviewType *int `json:"reviewType" dc:"ReviewType"`
	IsPassed *int `json:"isPassed" dc:"IsPassed"`
	Status *int `json:"status" dc:"Status"`
	Content string `json:"content" dc:"Content"`
}

// UserReviewExportRes 导出用户审核响应
type UserReviewExportRes struct {
	g.Meta `mime:"text/csv"`
}

// UserReviewImportReq 导入用户审核请求
type UserReviewImportReq struct {
	g.Meta `path:"/user_review/import" method:"post" mime:"multipart/form-data" tags:"用户审核" summary:"导入用户审核"`
}

// UserReviewImportRes 导入用户审核响应
type UserReviewImportRes struct {
	g.Meta  `mime:"application/json"`
	Success int `json:"success" dc:"成功条数"`
	Fail    int `json:"fail" dc:"失败条数"`
}

// UserReviewImportTemplateReq 下载用户审核导入模板
type UserReviewImportTemplateReq struct {
	g.Meta `path:"/user_review/import-template" method:"get" tags:"用户审核" summary:"下载用户审核导入模板"`
}

// UserReviewImportTemplateRes 下载用户审核导入模板响应
type UserReviewImportTemplateRes struct {
	g.Meta `mime:"text/csv"`
}

