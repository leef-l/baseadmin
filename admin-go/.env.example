# ─────────────────────────────────────────────────────────────
# GBaseAdmin 环境变量配置示例
# 如果通过 docker/dev/compose.ps1 启动，admin-go/.env 会由 docker/dev/.env 自动覆盖
# 本文件主要用于非 Docker 场景或手动恢复
# ─────────────────────────────────────────────────────────────

# ─────────────────────────────────────────────
# MySQL 配置
# ─────────────────────────────────────────────
# 默认对接 `docker/dev` 启动后的本机映射端口: 127.0.0.1:10020
MYSQL_ROOT_PASSWORD=4365d2c5953988
MYSQL_HOST=127.0.0.1
MYSQL_USER=sql_baseadmin_easytestdev_online
MYSQL_PASSWORD=4365d2c5953988
MYSQL_DATABASE=sql_baseadmin_easytestdev_online
MYSQL_PORT=10020

# ─────────────────────────────────────────────
# Redis 配置
# ─────────────────────────────────────────────
# 默认对接 `docker/dev` 启动后的本机映射端口: 127.0.0.1:10021, db=0
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=gbaseadmin123
REDIS_PORT=10021
REDIS_DB=0

# ─────────────────────────────────────────────
# JWT 配置
# ─────────────────────────────────────────────
JWT_SECRET=change_me

# ─────────────────────────────────────────────
# 服务端口配置
# ─────────────────────────────────────────────
SYSTEM_PORT=10022
UPLOAD_PORT=10023
FRONTEND_PORT=10024
ADMINER_PORT=10025

# ─────────────────────────────────────────────
# 前端运行时配置
# ─────────────────────────────────────────────
VITE_GLOB_API_URL=http://localhost:10022
